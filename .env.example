# =============================================================================
# Root ENV Example (deploy/ops)
# Copy file nay thanh .env tai root repo.
# KHONG bao gio commit secret that.
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose / Infrastructure
# -----------------------------------------------------------------------------
# Postgres password cho container postgres (dev/default).
POSTGRES_PASSWORD=postgres

# n8n host + webhook URL (doi sang domain that o production).
N8N_HOST=localhost
N8N_WEBHOOK_URL=https://localhost/
# Timezone cho n8n scheduler.
N8N_TIMEZONE=Asia/Ho_Chi_Minh
# Tenant mặc định cho workflow phase 2.2.6 (bắt buộc set đúng UUID tenant).
TENANT_ID=

# -----------------------------------------------------------------------------
# Deploy script options (optional)
# -----------------------------------------------------------------------------
# Base URL de deploy.sh va smoke_test.sh health-check.
API_BASE_URL=http://localhost:8000

# Timeout cho wait healthz (giay).
DEPLOY_HEALTH_TIMEOUT_SECONDS=60

# DEPLOY_NO_BUILD=1 de bo qua docker compose build.
DEPLOY_NO_BUILD=0

# Bat smoke test them cong staging 8001.
SMOKE_TEST_STAGING_8001=0
STAGING_API_BASE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# App ENV guide (nam o ai_content_director/.env)
# -----------------------------------------------------------------------------
# Copy ai_content_director/.env.example -> ai_content_director/.env
# Cac bien bat buoc toi thieu cho API:
# - DATABASE_URL
# - REDIS_URL (khuyen nghi)
# - OPENAI_API_KEY (neu dung AI generation)
# - FACEBOOK_PAGE_ID
# - FACEBOOK_ACCESS_TOKEN
# - GDRIVE_* (neu dung ingest tai san tu Google Drive)

# -----------------------------------------------------------------------------
# Security note
# -----------------------------------------------------------------------------
# Khong dat API key/token that trong file .env.example.
