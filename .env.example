# =============================================================================
# Root ENV example - cho deploy bang docker compose (repo root)
# Copy file nay thanh .env va KHONG commit secret that.
# =============================================================================

# -------- Docker Compose / infra --------
POSTGRES_PASSWORD=postgres
N8N_HOST=localhost
N8N_WEBHOOK_URL=https://localhost/

# -------- Deploy script options (optional) --------
# Base URL de deploy.sh va smoke_test.sh check health/openapi
API_BASE_URL=http://localhost:8000
# Timeout cho wait healthz (giay)
DEPLOY_HEALTH_TIMEOUT_SECONDS=60
# Bat smoke test them cong 8001: 1 = bat, 0 = tat
SMOKE_TEST_STAGING_8001=0
STAGING_API_BASE_URL=http://localhost:8001

# -------- App env guide --------
# API env chinh nam trong: ai_content_director/.env
# Ban hay copy: ai_content_director/.env.example -> ai_content_director/.env
# Cac bien bat buoc cho API:
# - DATABASE_URL
# - REDIS_URL (khuyen nghi)
# - OPENAI_API_KEY (neu dung AI generation)
# - FACEBOOK_PAGE_ID / FACEBOOK_ACCESS_TOKEN (neu dung publish/lead feature)
# - GDRIVE_* (neu dung ingest tai san tu Google Drive)

# -------- Security note --------
# Khong bao gio dat API key/token that vao .env.example.
