# =============================================================================
# Unified ENV template (single standard)
# Usage:
# - Local PC (Docker Compose):   copy to .env.local
# - VPS production:              copy to /opt/aiplatform/secrets/.env.prod
# - Compose reads ONE file only: API_ENV_FILE (default ./.env.local)
# =============================================================================

# -------------------------------
# App runtime
# -------------------------------
APP_ENV=local
LOG_LEVEL=INFO
ENABLE_INTERNAL_SCHEDULER=0

# Docker Compose internal network (api -> postgres/redis)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_content_director
REDIS_URL=redis://redis:6379/0

# -------------------------------
# OpenAI
# -------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.7
DAILY_BUDGET_USD=2.0
# OPENAI_INPUT_PRICE_PER_1M=0.15
# OPENAI_OUTPUT_PRICE_PER_1M=0.60

# -------------------------------
# Facebook / Meta
# -------------------------------
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
FB_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# -------------------------------
# Google Drive
# -------------------------------
GDRIVE_SA_JSON_PATH=
GDRIVE_READY_IMAGES_FOLDER_ID=
GDRIVE_READY_VIDEOS_FOLDER_ID=
GDRIVE_PROCESSED_FOLDER_ID=
GDRIVE_REJECTED_FOLDER_ID=
LOCAL_MEDIA_DIR=/opt/aiplatform/media_cache
ASSET_MAX_IMAGE_MB=10
ASSET_MAX_VIDEO_MB=200

# -------------------------------
# n8n / webhook
# -------------------------------
WEBHOOK_URL=
N8N_HOST=localhost
N8N_WEBHOOK_URL=https://localhost/
N8N_TIMEZONE=Asia/Ho_Chi_Minh
API_BASE_URL=http://localhost:8000
TENANT_ID=

# -------------------------------
# Deploy / smoke (optional)
# -------------------------------
DEPLOY_HEALTH_TIMEOUT_SECONDS=60
DEPLOY_NO_BUILD=0
SMOKE_TEST_STAGING_8001=0
STAGING_API_BASE_URL=http://localhost:8001

# -------------------------------
# Security note
# -------------------------------
# 1) KHONG commit .env.local / .env.prod
# 2) Secret thật chỉ đặt ở local machine hoặc /secrets trên VPS
# 3) Nếu nghi ngờ lộ key trong history: rotate ngay (xem docs/ROTATE_KEYS.md)
